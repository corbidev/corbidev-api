# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration
####> PROJECT INFO ###
NAME=symfony-api
BASE=mariadb
ENV=development

###> VERSIONS ###
BACKEND_VERSION=1.0.0
MARIADB_VERSION=11.8.6
ADMINER_VERSION=5.3.0
PHPMYADMIN_VERSION=5.2.3
###< VERSIONS ###

###> MYSQL/ mariadb - adminer ###
DATABASE_NAME=${NAME}_${BASE}
MYSQL_HOST=database
MYSQL_URL=127.0.0.1
MYSQL_ROOT_PASSWORD=P@ssW0rd!
MYSQL_DATABASE=${NAME}
MYSQL_USER=user
MYSQL_PASSWORD=password

MYSQL_HOST_API=database_api
MYSQL_URL_API=127.0.0.1
MYSQL_ROOT_PASSWORD_API=P@ssW0rd!
MYSQL_DATABASE_API=${NAME}_API
MYSQL_USER_API=user
MYSQL_PASSWORD_API=password


###> PORTS ###
# Ajustez les ports LOCALHOST si nécessaire pour éviter
# les conflits avec d'autres services sur votre machine
SQL_DOCKER_PORT=3306
SQL_LOCALHOST_PORT=3376

SQL_DOCKER_PORT_API=3306
SQL_LOCALHOST_PORT_API=3366

PHPMYADMIN_LOCALHOST_PORT=8081
PHPMYADMIN_DOCKER_PORT=80

ADMINER_DOCKER_PORT=8080
ADMINER_LOCALHOST_PORT=8070

# Ports pour smtp4dev
SMTP4DEV_DOCKER_SMTP_PORT=25
SMTP4DEV_LOCALHOST_SMTP_PORT=2525
SMTP4DEV_DOCKER_WEB_PORT=80
SMTP4DEV_LOCALHOST_WEB_PORT=3000

###< PORTS ###

###> FOLDERS ###
FOLDER_DATA=database

FOLDER_DATASQL=${FOLDER_DATA}/sql
FOLDER_DATABASE=${FOLDER_DATA}/${DATABASE_NAME}_auth

FOLDER_DATASQL_API=${FOLDER_DATA}/sql_api
FOLDER_DATABASE_API=${FOLDER_DATA}/${DATABASE_NAME}_api
###< FOLDERS ###


