# .env

####> PROJECT INFO ###
NAME=symfony-api
BASE=mariadb
####< PROJECT INFO ###

####> VERSIONS ###
BACKEND_VERSION=1.0.0
MARIADB_VERSION=11.7.0
####< VERSIONS ###

####> DOMAIN CONFIG ###

# Domaines (sera override selon environnement)

# Sous-domaines
AUTH_SUBDOMAIN=auth
API_SUBDOMAIN=api

# Domaine principal
NETWORK=https
DOMAIN=corbisier
EXT=test

# MAILER
MAIL_FROM=noreply@mail.fr
MAIL_TO=admin@mail.fr

SMTP_USER=user
SMTP_PASS=pass
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECUR=tls

# DOMAINE

APP_DOMAIN=${DOMAIN}.${EXT}

# Hosts
AUTH_HOST=${AUTH_SUBDOMAIN}.${APP_DOMAIN}
API_HOST=${API_SUBDOMAIN}.${APP_DOMAIN}

# URLs
AUTH_URL=${NETWORK}://${AUTH_HOST}
API_URL=${NETWORK}://${API_HOST}

# REGEX
API_HOST_REGEX=^${API_SUBDOMAIN}\.${DOMAIN}\.${EXT}$
AUTH_HOST_REGEX=^${AUTH_SUBDOMAIN}\.${DOMAIN}\.${EXT}$

####< DOMAIN CONFIG ###

####> MYSQL / MARIADB ###
DATABASE_NAME=${NAME}_${BASE}
MYSQL_HOST=database
MYSQL_URL=127.0.0.1
MYSQL_ROOT_PASSWORD=P@ssW0rd!
MYSQL_DATABASE=${NAME}
MYSQL_USER=user
MYSQL_PASSWORD=password

MYSQL_HOST_API=database_api
MYSQL_URL_API=127.0.0.1
MYSQL_ROOT_PASSWORD_API=P@ssW0rd!
MYSQL_DATABASE_API=${NAME}_API
MYSQL_USER_API=user
MYSQL_PASSWORD_API=password


####< MYSQL / MARIADB ###

####> PORTS ###
SQL_LOCALHOST_PORT=3306
SQL_LOCALHOST_PORT_API=3306
####< PORTS ###

####> SYMFONY ###
APP_ENV=dev
APP_SECRET=<VOTRE_APP_SECRET>
APP_SHARE_DIR=var/share
####< SYMFONY ###

####> ROUTING ###
DEFAULT_URI=${API_URL}
####< ROUTING ###

####> DOCTRINE ###
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4"

DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

# DATABASE_URL="postgresql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=16&charset=utf8"

# API DB
DATABASE_API_URL="mysql://${MYSQL_USER_API}:${MYSQL_PASSWORD_API}@${MYSQL_URL_API}:${SQL_LOCALHOST_PORT_API}/${MYSQL_DATABASE_API}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

# AUTH DB
DATABASE_AUTH_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

####< DOCTRINE ###

####> CORS ###
# sera override selon environnement
CORS_ALLOW_ORIGIN=^https?://(${AUTH_HOST}|${API_HOST})$

CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Content-Type,Authorization"
CORS_EXPOSE_HEADERS="Link"
CORS_MAX_AGE=3600
CORS_ALLOW_CREDENTIALS=true
####< CORS ###

####> JWT ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=<VOTRE_PASSPHRASE>
####< JWT ###

####> TENANT ###
TENANT_ALLOWED_DOMAINS=${AUTH_URL},${API_URL}
####< TENANT ###

###> symfony/mailer ###
# MAILER_DSN=smtp://localhost:1025
MAILER_DSN=smtp://${SMOT_USER}:${SMTP_PASS}@${SMTP_HOST}:${SMTP_PORT}?encryption=${SMTP_SECUR}&auth_mode=login
###< symfony/mailer ###

