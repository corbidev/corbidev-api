# .env

# ------------------------------------------------------------
# FICHIER MODELE
#
# - Ce fichier sert d'exemple pour construire votre `.env`.
# - Renseignez d'abord les variables du bloc "VARIABLES A RENSEIGNER".
# - Les variables du bloc "VARIABLES CONSTRUITES" sont dérivées automatiquement.
# ------------------------------------------------------------

####> VARIABLES A RENSEIGNER ###

# Projet / versions
# NAME: préfixe global du projet (sert aux noms DB)

NAME=symfony-api
BASE=mariadb
APP_VERSION=1.0.2
BACKEND_VERSION=1.0.0
MARIADB_VERSION=11.7.0

# Domaine principal
# NETWORK: schéma d'URL (http ou https)
# DOMAIN + EXT: ex. corbisier + test => corbisier.test
NETWORK=https
DOMAIN=corbisier
EXT=test

# Sous-domaines
# ex. AUTH_SUBDOMAIN=auth => auth.corbisier.test
AUTH_SUBDOMAIN=auth
API_SUBDOMAIN=api

# Mail
# Utilisé par Mailer et les commandes d'alerte (retry queue)
MAIL_FROM=noreply@mail.fr
MAIL_TO=admin@mail.fr
SMTP_USER=user
SMTP_PASS=pass
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECUR=tls

# MariaDB / MySQL
# MYSQL_URL(_API): hôte/IP vu par PHP (localhost, service Docker, etc.)

MYSQL_URL=127.0.0.1
MYSQL_DATABASE=${NAME}
MYSQL_USER=user
MYSQL_PASSWORD=password

MYSQL_URL_API=127.0.0.1
MYSQL_DATABASE_API=${NAME}_api
MYSQL_USER_API=user
MYSQL_PASSWORD_API=password

# Ports SQL
SQL_LOCALHOST_PORT=3306
SQL_LOCALHOST_PORT_API=3306

# Symfony / sécurité
# APP_SECRET: générer une vraie valeur aléatoire en production
# JWT_PASSPHRASE: passphrase de la clé privée JWT
# ADMIN_PASSWORD_HASH: valeur hashée (ne pas mettre un mot de passe en clair)
APP_ENV=dev
APP_SECRET=<VOTRE_APP_SECRET>
APP_SHARE_DIR=var/share
JWT_PASSPHRASE=<VOTRE_PASSPHRASE>
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=<MOT DE PASSE HASHER>

####< VARIABLES A RENSEIGNER ###

####> VARIABLES CONSTRUITES (SYMFONY / SYSTEME) ###

# Domaine
# Ces variables sont calculées à partir de NETWORK/DOMAIN/EXT/SUBDOMAIN
APP_DOMAIN=${DOMAIN}.${EXT}
AUTH_HOST=${AUTH_SUBDOMAIN}.${APP_DOMAIN}
API_HOST=${API_SUBDOMAIN}.${APP_DOMAIN}
AUTH_URL=${NETWORK}://${AUTH_HOST}
API_URL=${NETWORK}://${API_HOST}

# Endpoint cible de collecte des logs applicatifs
API_LOGS_ENDPOINT=${API_URL}/api/logs

# Regex host utilisées par la sécurité Symfony (firewalls)
# IMPORTANT: conserver l'échappement `\.`
API_HOST_REGEX=^${API_SUBDOMAIN}\.${DOMAIN}\.${EXT}$
AUTH_HOST_REGEX=^${AUTH_SUBDOMAIN}\.${DOMAIN}\.${EXT}$

# Cible routing
# URI de référence utilisée par certaines commandes / génération d'URL
DEFAULT_URI=${API_URL}

# Noms DB

# Doctrine
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4"

# Connexion DB principale (auth dans cette architecture)
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

# DATABASE_URL="postgresql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=16&charset=utf8"

# API DB
# Base dédiée au module API logs
DATABASE_API_URL="mysql://${MYSQL_USER_API}:${MYSQL_PASSWORD_API}@${MYSQL_URL_API}:${SQL_LOCALHOST_PORT_API}/${MYSQL_DATABASE_API}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

# AUTH DB
# Base dédiée au module auth
DATABASE_AUTH_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_URL}:${SQL_LOCALHOST_PORT}/${MYSQL_DATABASE}?serverVersion=${MARIADB_VERSION}-MariaDB&charset=utf8mb4"

# CORS
# sera override selon environnement
# Origines autorisées construites depuis AUTH_HOST/API_HOST
CORS_ALLOW_ORIGIN=^https?://(${AUTH_HOST}|${API_HOST})$

CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Content-Type,Authorization"
CORS_EXPOSE_HEADERS="Link"
CORS_MAX_AGE=3600
CORS_ALLOW_CREDENTIALS=true

# JWT
# Chemins des clés utilisés par lexik/jwt-authentication-bundle
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# Tenant
# Liste des domaines autorisés pour la résolution tenant
TENANT_ALLOWED_DOMAINS=${AUTH_URL},${API_URL}

###> symfony/mailer ###
# MAILER_DSN=smtp://localhost:1025

# DSN SMTP effectif construit depuis les variables SMTP ci-dessus
MAILER_DSN=smtp://${SMTP_USER}:${SMTP_PASS}@${SMTP_HOST}:${SMTP_PORT}?encryption=${SMTP_SECUR}&auth_mode=login
###< symfony/mailer ###

####< VARIABLES CONSTRUITES (SYMFONY / SYSTEME) ###