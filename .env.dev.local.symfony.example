# .env.dev.local
APP_ENV=dev

# Domaine principal (sera override selon environnement)
APP_DOMAIN=corbisier.fr
NETWORK=https

# Sous-domaines
AUTH_SUBDOMAIN=d1-auth
API_SUBDOMAIN=d1-api

# Hosts
AUTH_HOST=${AUTH_SUBDOMAIN}.${APP_DOMAIN}
API_HOST=${API_SUBDOMAIN}.${APP_DOMAIN}

# URLs
AUTH_URL=${NETWORK}://${AUTH_HOST}
API_URL=${NETWORK}://${API_HOST}

CORS_ALLOW_ORIGIN=^(${AUTH_URL}|${API_URL})$