{% extends 'admin/layout.html.twig' %}

{% block title %}API Consumers{% endblock %}

{% block body %}
<main class="admin-page">
    <section class="admin-shell wide">
        <div class="d-flex justify-content-between align-items-center mb-3 admin-topbar">
            <div>
                <h1 class="h3 admin-title">API Consumers</h1>
                <p class="admin-subtitle">Supervision des accès et statuts des clients applicatifs.</p>
            </div>
            <a href="/admin/logout" class="btn btn-outline-danger btn-soft">Déconnexion</a>
        </div>

        <a href="/admin/consumers/create" class="btn btn-brand text-white mb-3">Créer un consumer</a>

        <div class="table-wrap table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Domaine</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for c in consumers %}
                    <tr>
                        <td>{{ c.identifier }}</td>
                        <td>
                            {% if c.active %}
                            <span class="status-pill active">Actif</span>
                            {% else %}
                            <span class="status-pill inactive">Inactif</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="actions">
                                <a href="/admin/consumers/{{ c.id }}/edit" class="btn btn-sm btn-warning">Éditer</a>
                                <a href="/admin/consumers/{{ c.id }}/toggle" class="btn btn-sm btn-secondary">Basculer</a>
                                <a href="/admin/consumers/{{ c.id }}/delete" class="btn btn-sm btn-danger">Supprimer</a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</main>
{% endblock %}
