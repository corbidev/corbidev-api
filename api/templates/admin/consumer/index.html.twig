<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

<div class="d-flex justify-content-between mb-3">
    <h1>API Consumers</h1>
    <a href="/admin/logout" class="btn btn-outline-danger">Logout</a>
</div>

<a href="/admin/consumers/create" class="btn btn-primary mb-3">Créer</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Domaine</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for c in consumers %}
            <tr>
                <td>{{ c.identifier }}</td>
                <td>
                    {% if c.active %}
                        <span class="badge bg-success">Actif</span>
                    {% else %}
                        <span class="badge bg-danger">Inactif</span>
                    {% endif %}
                </td>
                <td>
                    <a href="/admin/consumers/{{ c.id }}/edit" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/admin/consumers/{{ c.id }}/toggle" class="btn btn-sm btn-secondary">Toggle</a>
                    <a href="/admin/consumers/{{ c.id }}/delete" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

</div>