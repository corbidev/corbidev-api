{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier Consumer{% endblock %}

{% block body %}
<main class="admin-page centered">
    <section class="admin-shell narrow">
        <h1 class="h3 admin-title">Modifier le consumer</h1>
        <p class="admin-subtitle">Mets à jour le mot de passe et l'état d'activation.</p>

        {% if error is defined and error %}
        <div class="alert alert-danger mb-3">{{ error }}</div>
        {% endif %}

        <form method="post" id="consumer-edit-form" novalidate>
            <label class="form-label fw-semibold">Identifiant</label>
            <input class="form-control mb-2" value="{{ consumer.identifier }}" disabled>

            <label class="form-label fw-semibold">Nouveau mot de passe</label>
            <input class="form-control mb-2" type="password" name="password" id="edit-password" placeholder="Laisser vide pour ne pas changer">

            <label class="form-label fw-semibold">Recopier le nouveau mot de passe</label>
            <input class="form-control mb-1" type="password" name="password_confirm" id="edit-password-confirm" placeholder="Recopier le nouveau mot de passe">
            <div class="invalid-feedback d-block mb-3" id="edit-password-feedback" style="display: none !important;">
                Les mots de passe ne correspondent pas.
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" role="switch" id="active" name="active" {% if consumer.active %}checked{% endif %}>
                <label class="form-check-label" for="active">Actif</label>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-brand text-white flex-grow-1">Sauvegarder</button>
                <a href="/admin/consumers" class="btn btn-outline-secondary btn-soft">Retour</a>
            </div>
        </form>
    </section>
</main>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    (function () {
        const form = document.getElementById('consumer-edit-form');
        const password = document.getElementById('edit-password');
        const confirm = document.getElementById('edit-password-confirm');
        const feedback = document.getElementById('edit-password-feedback');

        function validateMatch() {
            const hasAnyValue = password.value.length > 0 || confirm.value.length > 0;
            const mismatch = hasAnyValue && password.value !== confirm.value;
            confirm.setCustomValidity(mismatch ? 'Les mots de passe ne correspondent pas.' : '');
            feedback.style.display = mismatch ? 'block' : 'none';
            confirm.classList.toggle('is-invalid', mismatch);
        }

        password.addEventListener('input', validateMatch);
        confirm.addEventListener('input', validateMatch);
        form.addEventListener('submit', function (event) {
            validateMatch();

            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            }
        });
    })();
</script>
{% endblock %}
