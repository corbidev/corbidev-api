<div class="container mt-4">
<h1>Edit Consumer</h1>

<form method="post">
    <input class="form-control mb-2" value="{{ consumer.identifier }}" disabled>

    <input class="form-control mb-2" type="password" name="password" placeholder="Nouveau mot de passe">

    <label>
        <input type="checkbox" name="active" {% if consumer.active %}checked{% endif %}>
        Actif
    </label>

    <br><br>
    <button class="btn btn-primary">Sauvegarder</button>
</form>
</div>