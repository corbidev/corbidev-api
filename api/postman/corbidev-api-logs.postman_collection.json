{
    "info": {
        "_postman_id": "b2a98ceb-5f6e-4d8e-b4f3-f9d13d2b4f20",
        "name": "corbidev-api-logs",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth - Create Log Token (201)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 201', function () {",
                            "  pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test('Response has token payload', function () {",
                            "  const body = pm.response.json();",
                            "  pm.expect(body).to.have.property('token_type', 'Bearer');",
                            "  pm.expect(body).to.have.property('access_token').that.is.a('string').and.is.not.empty;",
                            "  pm.expect(body).to.have.property('expires_in').that.is.a('number');",
                            "});",
                            "",
                            "pm.test('Store JWT for next requests', function () {",
                            "  const body = pm.response.json();",
                            "  pm.collectionVariables.set('jwtToken', body.access_token);",
                            "  pm.collectionVariables.set('tokenExpiresIn', String(body.expires_in));",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"sourceApiKey\": \"{{sourceApiKey}}\",\n  \"clientSecret\": \"{{clientSecret}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": "{{baseUrl}}/api/logs/token"
            }
        },
        {
            "name": "Auth - Create Log Token (400 missing clientSecret)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 400 when clientSecret is missing', function () {",
                            "  pm.response.to.have.status(400);",
                            "});",
                            "",
                            "pm.test('Error message indicates missing clientSecret', function () {",
                            "  const body = pm.response.json();",
                            "  pm.expect(body).to.have.property('error').that.is.a('string');",
                            "  pm.expect(body.error).to.include('clientSecret');",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"sourceApiKey\": \"{{sourceApiKey}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": "{{baseUrl}}/api/logs/token"
            }
        },
        {
            "name": "Logs - Create (201 with Bearer)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 201', function () {",
                            "  pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test('Log entry created response shape', function () {",
                            "  const body = pm.response.json();",
                            "  pm.expect(body).to.have.property('id');",
                            "  pm.expect(body).to.have.property('status', 'created');",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwtToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"message\": \"Postman bearer test\",\n  \"url\": \"https://api.corbisier.test/api/test\",\n  \"level\": \"info\",\n  \"env\": \"dev\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": "{{baseUrl}}/api/logs"
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://127.0.0.1:8000"
        },
        {
            "key": "sourceApiKey",
            "value": "local-test-api-key-001"
        },
        {
            "key": "clientSecret",
            "value": "mon-secret-long-1234"
        },
        {
            "key": "jwtToken",
            "value": ""
        },
        {
            "key": "tokenExpiresIn",
            "value": ""
        }
    ]
}
