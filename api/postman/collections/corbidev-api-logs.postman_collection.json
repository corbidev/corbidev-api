            "name": "Logs - Create (400 invalid bearer)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 400 when bearer token is invalid', function () {",
                            "  pm.response.to.have.status(400);",
                            "});",
                            "",
                            "pm.test('Error indicates invalid or expired JWT', function () {",
                            "  const body = pm.response.json();",
                            "  pm.expect(body).to.have.property('error').that.is.a('string');",
                            "  pm.expect(body.error.toLowerCase()).to.satisfy(function (message) {",
                            "    return message.includes('jwt') || message.includes('token');",
                            "  });",
                            "});"
                        ]
                    }
                }
