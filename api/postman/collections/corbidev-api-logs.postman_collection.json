    "item": [
        {
            "name": "Auth - Create Log Token (201)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Status code is 201', function () {",
                            "  pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test('Response has token payload', function () {",
                            "  const body = pm.response.json();",
                            "  pm.expect(body).to.have.property('token_type', 'Bearer');",
                            "  pm.expect(body).to.have.property('access_token').that.is.a('string').and.is.not.empty;",
                            "  pm.expect(body).to.have.property('expires_in').that.is.a('number');",
                            "});",
                            "",
                            "pm.test('Store JWT for next requests', function () {",
                            "  const body = pm.response.json();",
                            "  pm.environment.set('jwtToken', body.access_token);",
                            "  pm.environment.set('tokenExpiresIn', String(body.expires_in));",
                            "});"
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                    }
                },
                {
                    "listen": "prerequest",
                    "script": {
                        "packages": {},
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"sourceApiKey\": \"{{sourceApiKey}}\",\n  \"clientSecret\": \"{{clientSecret}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/token",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "token"
                    ]
                }
            },
            "response": []
        },
